{
  "manifest_version": 3,
  "name": "Form Mitra",
  "version": "1.0.0",
  "description": "AI-powered form assistant sidebar for your browser.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Form Mitra"
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "permissions": ["sidePanel", "activeTab"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
